generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ------------------------------------------------------
 * ENUMS
 * ------------------------------------------------------
 */

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REFRESH
  REVOKE
}

enum BlockStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MeasurementFieldInputType {
  TEXT
  NUMBER
  DECIMAL
  SELECT
  RADIO
  CHECKBOX
  TEXTAREA
}

enum MeasurementVerificationStatus {
  NOT_VERIFIED
  VERIFIED_OK
  NEEDS_UPDATE
  UPDATED
}

enum GroupOrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  READY
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
}

enum OrderType {
  INDIVIDUAL
  GROUP_MEMBER
}

enum OrderSource {
  DREZAURA
  PHYSICAL_SHOP
  PHONE_CALL
  WHATSAPP
  ONLINE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CUTTING
  SEWING
  READY
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  CUTTING
  SEWING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  ADVANCE_PAID
  PARTIALLY_PAID
  PAID
  REFUNDED
}

enum OrderPaymentMode {
  CASH
  ONLINE_TRANSFER
  BANK_DEPOSIT
  CARD
  MIXED
}

enum PaymentCategory {
  FULL
  ADVANCE
  BALANCE
  COURIER
  REFUND
}

enum PaymentMethod {
  CASH
  ONLINE_TRANSFER
  BANK_DEPOSIT
  CARD
  OTHER
}

enum PaymentRecordStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum AttendanceDeviceType {
  FINGERPRINT
  FACE
  CARD
  MANUAL
  OTHER
}

enum AttendanceSyncMode {
  MANUAL
  PUSH
  PULL
  CLOUD
  CSV_IMPORT
}

enum AttendancePunchType {
  CHECK_IN
  CHECK_OUT
  BREAK_IN
  BREAK_OUT
  UNKNOWN
}

enum AttendanceVerifyMode {
  FINGERPRINT
  FACE
  CARD
  PIN
  MANUAL
  UNKNOWN
}

enum AttendanceRecordStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  LEAVE
  HOLIDAY
  OFF_DAY
}

enum AttendanceRecordSource {
  DEVICE
  MANUAL
  IMPORT
  SYSTEM
}

enum WhatsappTemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum WhatsappTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

enum WhatsappMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsappMessageType {
  TEXT
  TEMPLATE
  IMAGE
  DOCUMENT
  BUTTON
  INTERACTIVE
}

enum WhatsappMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

/**
 * ------------------------------------------------------
 * TENANT / AUTH / RBAC
 * ------------------------------------------------------
 */

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  customers         Customer[]
  categories        Category[]
  blocks            Block[]
  customerBlocks    CustomerBlock[]
  measurementFields MeasurementField[]
  measurements      Measurement[]
  orders            Order[]
  groupOrders       GroupOrder[]
  payments          Payment[]
  employees         Employee[]
  attendanceDevices AttendanceDevice[]
  attendanceLogs    AttendanceLog[]
  attendanceRecords AttendanceRecord[]
  auditLogs         AuditLog[]
  whatsappAccounts  WhatsappAccount[]
  whatsappMessages  WhatsappMessage[]

  @@index([slug])
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  firstName    String?
  lastName     String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberships Membership[]
  sessions    Session[]

  createdCustomers Customer[] @relation("CustomerCreatedBy")
  updatedCustomers Customer[] @relation("CustomerUpdatedBy")

  createdBlocks Block[] @relation("BlockCreatedBy")
  updatedBlocks Block[] @relation("BlockUpdatedBy")

  assignedCustomerBlocks CustomerBlock[] @relation("CustomerBlockAssignedBy")

  createdMeasurements  Measurement[] @relation("MeasurementCreatedBy")
  updatedMeasurements  Measurement[] @relation("MeasurementUpdatedBy")
  verifiedMeasurements Measurement[] @relation("MeasurementVerifiedBy")

  createdOrders Order[] @relation("OrderCreatedBy")
  updatedOrders Order[] @relation("OrderUpdatedBy")

  createdGroupOrders GroupOrder[] @relation("GroupOrderCreatedBy")
  updatedGroupOrders GroupOrder[] @relation("GroupOrderUpdatedBy")

  createdPayments Payment[] @relation("PaymentCreatedBy")
  updatedPayments Payment[] @relation("PaymentUpdatedBy")

  createdEmployees Employee[] @relation("EmployeeCreatedBy")
  updatedEmployees Employee[] @relation("EmployeeUpdatedBy")

  approvedAttendanceRecords AttendanceRecord[] @relation("AttendanceRecordApprovedBy")
  createdAttendanceRecords  AttendanceRecord[] @relation("AttendanceRecordCreatedBy")
  updatedAttendanceRecords  AttendanceRecord[] @relation("AttendanceRecordUpdatedBy")

  auditLogs AuditLog[] @relation("ActorAuditLogs")
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  status           SessionStatus @default(ACTIVE)
  userAgent        String?
  ipAddress        String?
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([roleId])
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships     Membership[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      PermissionAction
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/**
 * ------------------------------------------------------
 * CATEGORY / MEASUREMENT FIELD DEFINITIONS
 * ------------------------------------------------------
 */

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  blocks            Block[]
  orderItems        OrderItem[]
  measurementFields MeasurementField[]
  measurements      Measurement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([name])
}

model MeasurementField {
  id         String                    @id @default(cuid())
  tenantId   String
  categoryId String
  code       String
  label      String
  inputType  MeasurementFieldInputType @default(TEXT)
  unit       String?
  sortOrder  Int                       @default(0)
  isRequired Boolean                   @default(false)
  isActive   Boolean                   @default(true)
  helpText   String?
  options    Json?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  values MeasurementValue[]

  @@unique([categoryId, code])
  @@index([tenantId])
  @@index([categoryId])
  @@index([code])
  @@index([isActive])
}

/**
 * ------------------------------------------------------
 * CUSTOMER
 * ------------------------------------------------------
 */

model Customer {
  id             String   @id @default(cuid())
  tenantId       String
  fullName       String
  phoneNumber    String?
  alternatePhone String?
  hospitalName   String?
  town           String?
  address        String?
  notes          String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  customerBlocks    CustomerBlock[]
  measurements      Measurement[]
  orders            Order[]
  coordinatorGroups GroupOrder[]      @relation("GroupOrderCoordinator")
  payments          Payment[]
  whatsappMessages  WhatsappMessage[]

  @@index([tenantId])
  @@index([fullName])
  @@index([phoneNumber])
  @@index([alternatePhone])
  @@index([town])
}

/**
 * ------------------------------------------------------
 * BLOCKS
 * ------------------------------------------------------
 */

model Block {
  id              String      @id @default(cuid())
  tenantId        String
  categoryId      String
  blockNumber     String
  readyMadeSize   String?
  sizeLabel       String?
  fitNotes        String?
  versionNo       Int         @default(1)
  previousBlockId String?
  description     String?
  status          BlockStatus @default(ACTIVE)
  lastUsedAt      DateTime?
  remarks         String?
  legacyId        Int?
  createdById     String?
  updatedById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  previousBlock Block?  @relation("BlockVersions", fields: [previousBlockId], references: [id], onDelete: SetNull)
  nextVersions  Block[] @relation("BlockVersions")

  createdBy User? @relation("BlockCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("BlockUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  customerBlocks CustomerBlock[]
  measurements   Measurement[]
  orderItems     OrderItem[]

  @@unique([tenantId, blockNumber, categoryId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([blockNumber])
  @@index([status])
  @@index([legacyId])
}

model CustomerBlock {
  id           String   @id @default(cuid())
  tenantId     String
  customerId   String
  blockId      String
  isDefault    Boolean  @default(false)
  assignedById String?
  assignedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  block      Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  assignedBy User?    @relation("CustomerBlockAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([customerId, blockId])
  @@index([tenantId])
  @@index([customerId])
  @@index([blockId])
  @@index([isDefault])
}

/**
 * ------------------------------------------------------
 * MEASUREMENT
 * ------------------------------------------------------
 */

model Measurement {
  id         String @id @default(cuid())
  tenantId   String
  customerId String
  blockId    String
  categoryId String

  measurementNumber String?

  verificationStatus MeasurementVerificationStatus @default(NOT_VERIFIED)
  verifiedAt         DateTime?
  verifiedById       String?
  verificationNote   String?

  isActive  Boolean @default(true)
  versionNo Int     @default(1)

  previousMeasurementId String?
  notes                 String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  block    Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  previousMeasurement Measurement?  @relation("MeasurementVersions", fields: [previousMeasurementId], references: [id], onDelete: SetNull)
  nextMeasurements    Measurement[] @relation("MeasurementVersions")

  createdBy  User? @relation("MeasurementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User? @relation("MeasurementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  verifiedBy User? @relation("MeasurementVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  values     MeasurementValue[]
  orderItems OrderItem[]

  @@unique([tenantId, measurementNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([blockId])
  @@index([categoryId])
  @@index([isActive])
  @@index([verificationStatus])
  @@index([measurementNumber])
  @@index([previousMeasurementId])
}

model MeasurementValue {
  id            String   @id @default(cuid())
  measurementId String
  fieldId       String
  value         String?
  numericValue  Decimal? @db.Decimal(10, 2)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  measurement Measurement      @relation(fields: [measurementId], references: [id], onDelete: Cascade)
  field       MeasurementField @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@unique([measurementId, fieldId])
  @@index([measurementId])
  @@index([fieldId])
}

/**
 * ------------------------------------------------------
 * GROUP ORDERS
 * ------------------------------------------------------
 */

model GroupOrder {
  id       String @id @default(cuid())
  tenantId String

  groupOrderNumber String

  coordinatorCustomerId String?

  title        String?
  hospitalName String?
  town         String?

  contactName  String?
  contactPhone String?

  deliveryAddress String?
  deliveryTown    String?

  status GroupOrderStatus @default(DRAFT)

  totalOrders Int @default(0)
  totalQty    Int @default(0)

  totalAmount    Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  courierCharges Decimal @default(0) @db.Decimal(12, 2)

  expectedDeliveryDate DateTime?
  deliveredAt          DateTime?

  notes String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  coordinatorCustomer Customer? @relation("GroupOrderCoordinator", fields: [coordinatorCustomerId], references: [id], onDelete: SetNull)

  createdBy User? @relation("GroupOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("GroupOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  orders           Order[]
  payments         Payment[]
  whatsappMessages WhatsappMessage[]

  @@unique([tenantId, groupOrderNumber])
  @@index([tenantId])
  @@index([groupOrderNumber])
  @@index([coordinatorCustomerId])
  @@index([status])
}

/**
 * ------------------------------------------------------
 * ORDERS
 * ------------------------------------------------------
 */

model Order {
  id       String @id @default(cuid())
  tenantId String

  orderNumber String

  customerId   String
  groupOrderId String?

  orderType OrderType @default(INDIVIDUAL)

  hospitalName    String?
  town            String?
  customerAddress String?

  status        OrderStatus       @default(PENDING)
  orderSource   OrderSource       @default(PHYSICAL_SHOP)
  paymentStatus PaymentStatus     @default(UNPAID)
  paymentMode   OrderPaymentMode?

  totalQty       Int     @default(0)
  totalAmount    Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  courierCharges Decimal @default(0) @db.Decimal(12, 2)

  orderDate    DateTime  @default(now())
  promisedDate DateTime?
  completedAt  DateTime?
  deliveredAt  DateTime?

  notes        String?
  specialNotes String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  groupOrder GroupOrder? @relation(fields: [groupOrderId], references: [id], onDelete: SetNull)

  createdBy User? @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("OrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  items            OrderItem[]
  payments         Payment[]
  whatsappMessages WhatsappMessage[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([orderNumber])
  @@index([customerId])
  @@index([groupOrderId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderDate])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  categoryId String

  blockId       String?
  measurementId String?

  itemDescription String

  quantity  Int     @default(1)
  unitPrice Decimal @default(0) @db.Decimal(12, 2)
  lineTotal Decimal @default(0) @db.Decimal(12, 2)

  notes      String?
  tailorNote String?

  status OrderItemStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  block       Block?       @relation(fields: [blockId], references: [id], onDelete: SetNull)
  measurement Measurement? @relation(fields: [measurementId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([categoryId])
  @@index([blockId])
  @@index([measurementId])
  @@index([status])
}

/**
 * ------------------------------------------------------
 * PAYMENTS
 * ------------------------------------------------------
 */

model Payment {
  id       String @id @default(cuid())
  tenantId String

  paymentNumber String

  orderId      String?
  groupOrderId String?
  customerId   String?

  paymentCategory PaymentCategory
  paymentMethod   PaymentMethod

  paidAmount     Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal @default(0) @db.Decimal(12, 2)
  courierCharges Decimal @default(0) @db.Decimal(12, 2)

  onlineTransfer Boolean @default(false)
  bankName       String?
  bankReference  String?
  transactionNo  String?

  paymentDate DateTime @default(now())
  paymentTime String?

  status PaymentRecordStatus @default(COMPLETED)

  orderNoSnapshot         String?
  customerNameSnapshot    String?
  hospitalSnapshot        String?
  townSnapshot            String?
  customerAddressSnapshot String?
  categorySnapshot        String?
  unitSnapshot            String?
  qtySnapshot             Int?

  specialNotes String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  order      Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  groupOrder GroupOrder? @relation(fields: [groupOrderId], references: [id], onDelete: SetNull)
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdBy User? @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("PaymentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  whatsappMessages WhatsappMessage[]

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@index([paymentNumber])
  @@index([orderId])
  @@index([groupOrderId])
  @@index([customerId])
  @@index([paymentCategory])
  @@index([paymentMethod])
  @@index([paymentDate])
}

/**
 * ------------------------------------------------------
 * EMPLOYEES / ATTENDANCE
 * ------------------------------------------------------
 */

model Employee {
  id       String @id @default(cuid())
  tenantId String

  employeeNumber String
  fullName       String
  phoneNumber    String?
  nicNumber      String?
  designation    String?
  department     String?
  joinedDate     DateTime?
  resignedDate   DateTime?

  biometricUserId String?

  basicSalary Decimal? @db.Decimal(12, 2)
  dailyWage   Decimal? @db.Decimal(12, 2)
  hourlyRate  Decimal? @db.Decimal(12, 2)

  isActive Boolean @default(true)

  notes String?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdBy User? @relation("EmployeeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("EmployeeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  attendanceLogs    AttendanceLog[]
  attendanceRecords AttendanceRecord[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([employeeNumber])
  @@index([fullName])
  @@index([biometricUserId])
  @@index([department])
  @@index([isActive])
}

model AttendanceDevice {
  id       String @id @default(cuid())
  tenantId String

  deviceName String
  deviceCode String

  deviceType AttendanceDeviceType @default(FINGERPRINT)
  syncMode   AttendanceSyncMode   @default(MANUAL)

  serialNumber String?
  ipAddress    String?
  port         Int?
  location     String?

  isActive Boolean @default(true)

  lastSyncedAt DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  attendanceLogs AttendanceLog[]

  @@unique([tenantId, deviceCode])
  @@index([tenantId])
  @@index([deviceCode])
  @@index([deviceType])
  @@index([syncMode])
  @@index([isActive])
}

model AttendanceLog {
  id       String @id @default(cuid())
  tenantId String

  employeeId String?
  deviceId   String?

  biometricUserId String
  punchTime       DateTime

  punchType  AttendancePunchType  @default(UNKNOWN)
  verifyMode AttendanceVerifyMode @default(UNKNOWN)

  rawPayload Json?

  isProcessed Boolean   @default(false)
  processedAt DateTime?

  createdAt DateTime @default(now())

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  device   AttendanceDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, biometricUserId, punchTime])
  @@index([tenantId])
  @@index([employeeId])
  @@index([deviceId])
  @@index([biometricUserId])
  @@index([punchTime])
  @@index([punchType])
  @@index([isProcessed])
}

model AttendanceRecord {
  id       String @id @default(cuid())
  tenantId String

  employeeId String

  attendanceDate DateTime

  firstIn DateTime?
  lastOut DateTime?

  status AttendanceRecordStatus @default(PRESENT)
  source AttendanceRecordSource @default(DEVICE)

  totalMinutes    Int @default(0)
  lateMinutes     Int @default(0)
  overtimeMinutes Int @default(0)

  expectedInTime  String?
  expectedOutTime String?

  notes String?

  approvedById String?
  approvedAt   DateTime?

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  approvedBy User? @relation("AttendanceRecordApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  createdBy  User? @relation("AttendanceRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User? @relation("AttendanceRecordUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, employeeId, attendanceDate])
  @@index([tenantId])
  @@index([employeeId])
  @@index([attendanceDate])
  @@index([status])
  @@index([source])
}

/**
 * ------------------------------------------------------
 * AUDIT
 * ------------------------------------------------------
 */

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      AuditAction
  entityType  String
  entityId    String?
  path        String?
  method      String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

/**
 * ------------------------------------------------------
 * WHATSAPP INTEGRATION
 * ------------------------------------------------------
 */

model WhatsappAccount {
  id       String @id @default(cuid())
  tenantId String

  businessName      String?
  phoneNumber       String
  phoneNumberId     String
  businessAccountId String?

  accessToken        String
  webhookVerifyToken String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  templates WhatsappTemplate[]
  messages  WhatsappMessage[]

  @@index([tenantId])
  @@index([phoneNumberId])
}

model WhatsappTemplate {
  id                String @id @default(cuid())
  tenantId          String
  whatsappAccountId String

  name         String
  category     WhatsappTemplateCategory
  languageCode String                 @default("en")
  status       WhatsappTemplateStatus @default(PENDING)

  description String?
  bodyPreview String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappAccount WhatsappAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, languageCode])
  @@index([tenantId])
  @@index([whatsappAccountId])
  @@index([status])
}

model WhatsappMessage {
  id                String @id @default(cuid())
  tenantId          String
  whatsappAccountId String

  customerId   String?
  orderId      String?
  groupOrderId String?
  paymentId    String?

  direction   WhatsappMessageDirection
  messageType WhatsappMessageType
  status      WhatsappMessageStatus    @default(PENDING)

  whatsappMessageId String?

  fromPhone String?
  toPhone   String

  templateName String?
  languageCode String?

  body    String?
  payload Json?

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?

  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order      Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  groupOrder GroupOrder? @relation(fields: [groupOrderId], references: [id], onDelete: SetNull)
  payment    Payment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([whatsappAccountId])
  @@index([customerId])
  @@index([orderId])
  @@index([groupOrderId])
  @@index([paymentId])
  @@index([whatsappMessageId])
  @@index([status])
  @@index([createdAt])
}